# Silver Tier AI Employee -- Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is in .gitignore -- NEVER commit real credentials.

# ── Anthropic (Required for AI reasoning) ─────────────────────────────────
# Get key from: https://console.anthropic.com/settings/keys
# Alternative: Use Ollama (local AI) - set to empty to disable
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Gmail Watcher (IMAP - reads emails) ───────────────────────────────────
# Setup: Enable 2FA → Create App Password at https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=you@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Email Sender (SMTP - sends replies) ──────────────────────────────────
# Same as above or different email for sending
# Required for auto-reply automation
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── WhatsApp (managed via Playwright session -- no API key needed) ───────
# Session stored at: silver_tier/silver_tier/whatsapp_session/
# Run once: python whatsapp_watcher.py --setup

# ── LinkedIn (managed via Playwright session -- no API key needed) ───────
# Session stored at: silver_tier/silver_tier/linkedin_session/
# Company page slug (for company posts)
LINKEDIN_COMPANY_SLUG=your-company-slug

# ── Optional: Ollama (Local AI - free alternative to Anthropic) ─────────
# Install: https://ollama.com/download/windows
# Then run: ollama pull llama3.2
# Set to empty string to use Anthropic instead
OLLAMA_MODEL=
OLLAMA_BASE_URL=http://localhost:11434
